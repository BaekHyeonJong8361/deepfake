# ===================================================================
# 대용량 모델 가중치 / 데이터 (GitHub 100MB 제한 · 절대 커밋 금지)
# ===================================================================
*.pth
*.pt
*.h5
*.ckpt
*.onnx
*.pb
*.tar
*.tar.gz
*.tgz
*.zip

# 원본/전처리 데이터셋 및 중간 산출 디렉토리
datasets/
dfdc_raw/
ff_data/
ff_data.tar
preprocessed_faces/
test_inputs/
ood_retest/
final/
df40_weights/
saved_models/
insta/
insta_real/
crawled_sns_images/
