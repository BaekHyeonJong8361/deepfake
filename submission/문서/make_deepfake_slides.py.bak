# ── 슬라이드 클론 + 텍스트 교체 함수 ───────────────────────────────────────────

def replace_text_in_xml(element, replacements):
    """
    두 단계 텍스트 교체:
      Phase 1 — 단락(paragraph) 레벨: run이 여러 개로 쪼개진 경우 처리
      Phase 2 — 단일 <a:t> 레벨: 일반 케이스
    긴 key를 먼저 처리해 substring 오염 방지.
    """
    NS_A_T = NS_A + 't'
    NS_A_P = NS_A + 'p'
    NS_A_R = NS_A + 'r'

    # 긴 key 먼저 처리 (substring 충돌 방지)
    sorted_reps = sorted(replacements.items(), key=lambda x: -len(x[0]))

    # Phase 1: paragraph 레벨 (2개 이상 run으로 쪼개진 텍스트 처리)
    for para in element.iter(NS_A_P):
        runs = [child for child in para if child.tag == NS_A_R]
        if len(runs) < 2:
            continue
        t_elems = [r.find(NS_A_T) for r in runs]
        valid = [(r, t) for r, t in zip(runs, t_elems) if t is not None]
        if not valid:
            continue
        full_text = ''.join(t.text or '' for _, t in valid)
        modified = False
        for old, new in sorted_reps:
            if old in full_text:
                full_text = full_text.replace(old, new)
                modified = True
        if modified:
            valid[0][1].text = full_text
            for _, t in valid[1:]:
                t.text = ''

    # Phase 2: 단일 <a:t> 레벨 (첫 매칭 키만 적용 — cascade 치환 방지)
    for t_elem in element.iter(NS_A_T):
        if t_elem.text:
            for old, new in sorted_reps:
                if old in t_elem.text:
                    t_elem.text = t_elem.text.replace(old, new)
                    break  # 한 element에 첫 번째 매칭 키만 적용


def clone_slide_with_replacements(src_prs, src_idx, dst_prs, replacements):
    """T2V 슬라이드를 클론해서 새 prs에 추가"""
    src_slide = src_prs.slides[src_idx]

    blank_layout = dst_prs.slide_layouts[6]
    new_slide = dst_prs.slides.add_slide(blank_layout)

    sp_tree = new_slide.shapes._spTree
    for child in list(sp_tree):
        sp_tree.remove(child)

    src_sp_tree = src_slide.shapes._spTree
    for child in src_sp_tree:
        sp_tree.append(copy.deepcopy(child))

    try:
        src_bg = src_slide.background._element
        new_bg = new_slide.background._element
        new_bg.getparent().replace(new_bg, copy.deepcopy(src_bg))
    except Exception:
        pass

    combined = {**COMMON, **replacements}
    replace_text_in_xml(new_slide._element, combined)

    return new_slide


# ── 메인 실행 ────────────────────────────────────────────────────────────────

def main():
    print("T2V 템플릿 로드 중...")
    src_prs = Presentation(SRC)

    shutil.copy(SRC, OUT)
    dst_prs = Presentation(OUT)

    print(f"기존 슬라이드 {len(dst_prs.slides)}개 제거 중...")
    from pptx.oxml.ns import qn
    sldIdLst = dst_prs.slides._sldIdLst
    for sldId_elem in list(sldIdLst):
        rId = sldId_elem.get(qn('r:id'))
        dst_prs.part.drop_rel(rId)
        sldIdLst.remove(sldId_elem)

    print(f"딥페이크 슬라이드 {len(SLIDES)}장 생성 중...")
    for i, (src_idx, replacements) in enumerate(SLIDES):
        clone_slide_with_replacements(src_prs, src_idx, dst_prs, replacements)
        print(f"  [{i+1}/{len(SLIDES)}] T2V[{src_idx+1}] 기반 → 완료")

    dst_prs.save(OUT)
    print(f"\n✅ 저장 완료: {OUT}")
    print(f"   슬라이드 수: {len(dst_prs.slides)}장")


if __name__ == '__main__':
    main()
